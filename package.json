{
  "name": "@mrchartist/memvault",
  "version": "2.0.0",
  "mcpName": "io.github.mrchartist/memvault",
  "description": "Universal AI Context Layer — Auto-sync your entire digital life (Git, VS Code, Browser, Clipboard) to Claude, Cursor, and any MCP client.",
  "bin": {
    "memvault": "cli.mjs",
    "memvault-mcp": "mcp-server.mjs"
  },
  "type": "module",
  "main": "server.mjs",
  "scripts": {
    "start": "node server.mjs",
    "mcp": "node mcp-server.mjs",
    "sync": "node sync-antigravity.mjs",
    "sync:git": "node sync-git.mjs",
    "sync:clipboard": "node sync-clipboard.mjs",
    "sync:vscode": "node sync-vscode.mjs",
    "sync:files": "node sync-files.mjs",
    "sync:system": "node sync-system.mjs",
    "sync:all": "node sync-all.mjs",
    "dev": "node --watch server.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "personal-knowledge-base",
    "second-brain",
    "self-hosted",
    "knowledge-vault",
    "ai-work-log",
    "developer-diary",
    "note-taking",
    "sqlite",
    "full-text-search",
    "antigravity"
  ],
  "author": "Rohit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrChartist/memvault.git"
  },
  "homepage": "https://github.com/MrChartist/memvault#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
